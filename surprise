<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Open for a Surprise 🤎</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #f6efe6;
    --blush: #e7d6c2;
    --rose: #c9a884;
    --deep-rose: #9a7a56;
    --sage: #b6a890;
    --gold: #c2a06a;
    --ink: #5c4733;
    --soft-ink: #927f6a;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
height: 100%;
overflow: hidden;
}

body {
font-family: ‘Cormorant Garamond’, serif;
background:
radial-gradient(circle at 20% 20%, rgba(231, 214, 194, 0.7), transparent 50%),
radial-gradient(circle at 80% 70%, rgba(182, 168, 144, 0.4), transparent 55%),
radial-gradient(circle at 50% 100%, rgba(194, 160, 106, 0.3), transparent 60%),
linear-gradient(160deg, #f6efe6 0%, #ece0d0 100%);
display: flex;
align-items: center;
justify-content: center;
min-height: 100vh;
position: relative;
color: var(–ink);
-webkit-tap-highlight-color: transparent;
}

/* floating decorative hearts in the background */
.bg-heart {
position: absolute;
color: rgba(154, 122, 86, 0.22);
font-size: 1.4rem;
animation: drift 14s ease-in-out infinite;
pointer-events: none;
user-select: none;
}
@keyframes drift {
0%, 100% { transform: translateY(0) rotate(-8deg); opacity: 0.4; }
50% { transform: translateY(-26px) rotate(8deg); opacity: 0.8; }
}

.stage {
position: relative;
width: 100%;
max-width: 440px;
padding: 24px;
text-align: center;
z-index: 5;
}

.prompt {
font-size: 1.35rem;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–soft-ink);
margin-bottom: 26px;
font-weight: 500;
animation: fadeInUp 1s ease both;
}
.prompt .tap-word {
font-family: ‘Caveat’, cursive;
text-transform: none;
font-size: 1.9rem;
letter-spacing: 0;
color: var(–deep-rose);
display: inline-block;
animation: pulse 2.2s ease-in-out infinite;
}
@keyframes pulse {
0%, 100% { transform: scale(1); }
50% { transform: scale(1.08); }
}

/* ENVELOPE */
.envelope-wrap {
position: relative;
width: 300px;
height: 200px;
margin: 0 auto;
cursor: pointer;
perspective: 1200px;
animation: fadeInUp 1.1s ease 0.2s both;
}
.envelope-wrap.opened { cursor: default; }

.floaty { animation: floaty 4s ease-in-out infinite; }
@keyframes floaty {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-10px); }
}

.env-body {
position: absolute;
inset: 0;
background: linear-gradient(150deg, #e8d8c2 0%, #ddc7a9 100%);
border-radius: 10px;
box-shadow: 0 22px 45px -18px rgba(92, 71, 51, 0.55),
inset 0 1px 0 rgba(255,255,255,0.5);
}

/* the letter that slides up */
.letter {
position: absolute;
left: 14px;
right: 14px;
bottom: 12px;
height: 250px;
background: linear-gradient(175deg, #fffdf9 0%, #f7ede0 100%);
border-radius: 8px 8px 4px 4px;
box-shadow: 0 -6px 20px -8px rgba(92,71,51,0.3);
z-index: 2;
transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
transform: translateY(0);
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
padding: 18px;
overflow: hidden;
}
.opened .letter { transform: translateY(-188px); }

.letter-mini {
font-family: ‘Caveat’, cursive;
color: var(–deep-rose);
font-size: 1.5rem;
line-height: 1.2;
opacity: 0;
transition: opacity 0.4s ease 0.5s;
}
.opened .letter-mini { opacity: 1; }

/* envelope front pocket (covers bottom of letter) */
.env-front {
position: absolute;
inset: 0;
z-index: 3;
border-radius: 10px;
background: linear-gradient(150deg, #ddc7a9 0%, #d0b48f 100%);
clip-path: polygon(0 38%, 50% 100%, 100% 38%, 100% 100%, 0 100%);
box-shadow: inset 0 2px 5px rgba(255,255,255,0.4);
}

/* the flap */
.env-flap {
position: absolute;
top: 0; left: 0; right: 0;
height: 0;
z-index: 4;
border-left: 150px solid transparent;
border-right: 150px solid transparent;
border-top: 116px solid #d8c0a0;
transform-origin: top;
transition: transform 0.6s ease, z-index 0s 0.6s;
filter: drop-shadow(0 4px 6px rgba(92,71,51,0.2));
}
.opened .env-flap {
transform: rotateX(180deg);
z-index: 1;
}

/* wax seal */
.seal {
position: absolute;
top: 78px; left: 50%;
transform: translateX(-50%);
width: 54px; height: 54px;
background: radial-gradient(circle at 35% 30%, var(–rose), var(–deep-rose));
border-radius: 50%;
z-index: 6;
display: flex; align-items: center; justify-content: center;
color: #fdf6ec;
font-family: ‘Caveat’, cursive;
font-size: 1.7rem;
box-shadow: 0 6px 14px -4px rgba(92,71,51,0.6),
inset 0 -3px 6px rgba(0,0,0,0.15),
inset 0 2px 4px rgba(255,255,255,0.4);
transition: transform 0.4s ease, opacity 0.4s ease;
}
.opened .seal {
transform: translateX(-50%) scale(0.4);
opacity: 0;
}

/* THE REVEAL */
.reveal {
position: absolute;
inset: 0;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 6px;
opacity: 0;
pointer-events: none;
transform: translateY(20px) scale(0.9);
transition: opacity 0.8s ease 0.7s, transform 0.8s cubic-bezier(0.22,1,0.36,1) 0.7s;
}
.reveal.show {
opacity: 1;
transform: translateY(0) scale(1);
pointer-events: auto;
}

.reveal .eyebrow {
font-size: 1.05rem;
letter-spacing: 0.32em;
text-transform: uppercase;
color: var(–sage);
font-weight: 600;
}
.reveal h1 {
font-family: ‘Caveat’, cursive;
font-size: 3.6rem;
line-height: 1;
color: var(–deep-rose);
font-weight: 700;
margin: 4px 0;
text-shadow: 0 2px 10px rgba(154,122,86,0.25);
}
.reveal .year {
font-family: ‘Cormorant Garamond’, serif;
font-size: 2.8rem;
font-weight: 600;
letter-spacing: 0.04em;
color: var(–ink);
line-height: 1.05;
background: linear-gradient(120deg, var(–deep-rose), var(–gold));
-webkit-background-clip: text;
background-clip: text;
-webkit-text-fill-color: transparent;
}
.reveal .sub {
font-size: 1.45rem;
font-style: italic;
color: var(–soft-ink);
margin-top: 10px;
}
.reveal .heart-row {
font-size: 1.2rem;
color: var(–rose);
letter-spacing: 0.3em;
margin-top: 8px;
}

.stage .hide-when-open {
transition: opacity 0.5s ease;
}
.stage.is-open .hide-when-open { opacity: 0; pointer-events: none; }

@keyframes fadeInUp {
from { opacity: 0; transform: translateY(24px); }
to { opacity: 1; transform: translateY(0); }
}

/* confetti */
.confetti {
position: fixed;
top: -20px;
width: 10px; height: 14px;
z-index: 20;
will-change: transform;
pointer-events: none;
}

.replay {
margin-top: 34px;
background: none;
border: 1.5px solid var(–rose);
color: var(–deep-rose);
font-family: ‘Cormorant Garamond’, serif;
font-size: 1rem;
letter-spacing: 0.15em;
text-transform: uppercase;
padding: 9px 22px;
border-radius: 30px;
cursor: pointer;
opacity: 0;
transition: all 0.4s ease;
}
.stage.is-open .replay {
opacity: 1;
transition: all 0.5s ease 1.4s;
}
.replay:hover { background: var(–rose); color: #fff; }
</style>

</head>
<body>
  <div class="stage" id="stage">
    <p class="prompt hide-when-open">
      <span class="tap-word">tap to open</span><br>a little surprise
    </p>

```
<div class="envelope-wrap floaty" id="envelope">
  <div class="env-body"></div>
  <div class="letter">
    <div class="letter-mini">it's true... 💕</div>
  </div>
  <div class="env-front"></div>
  <div class="env-flap"></div>
  <div class="seal">♥</div>
</div>

<div class="reveal" id="reveal">
  <span class="eyebrow">Arriving</span>
  <h1>Baby</h1>
  <span class="year">January 2027</span>
  <p class="sub">our greatest adventure begins</p>
  <div class="heart-row">♥ ♥ ♥</div>
</div>

