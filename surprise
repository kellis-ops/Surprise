```

  </div>

<script>
  // scatter background hearts
  (function () {
    const hearts = ['♥','❤','💕','🤍'];
    for (let i = 0; i < 14; i++) {
      const h = document.createElement('div');
      h.className = 'bg-heart';
      h.textContent = hearts[Math.floor(Math.random()*hearts.length)];
      h.style.left = Math.random()*100 + 'vw';
      h.style.top = Math.random()*100 + 'vh';
      h.style.fontSize = (0.9 + Math.random()*1.6) + 'rem';
      h.style.animationDelay = (Math.random()*8) + 's';
      h.style.animationDuration = (10 + Math.random()*8) + 's';
      document.body.appendChild(h);
    }
  })();

  const stage = document.getElementById('stage');
  const envelope = document.getElementById('envelope');
  const reveal = document.getElementById('reveal');
  const replay = document.getElementById('replay');
  let opened = false;

  function fireConfetti() {
    const colors = ['#c9a884','#9a7a56','#b6a890','#c2a06a','#e7d6c2','#fffdf9'];
    for (let i = 0; i < 90; i++) {
      const c = document.createElement('div');
      c.className = 'confetti';
      const color = colors[Math.floor(Math.random()*colors.length)];
      const isHeart = Math.random() > 0.7;
      if (isHeart) {
        c.textContent = '♥';
        c.style.color = color;
        c.style.fontSize = (12 + Math.random()*12) + 'px';
        c.style.background = 'none';
      } else {
        c.style.background = color;
        c.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      }
      c.style.left = Math.random()*100 + 'vw';
      const dur = 2.6 + Math.random()*2.4;
      const drift = (Math.random()*200 - 100);
      const rot = Math.random()*720 - 360;
      document.body.appendChild(c);
      c.animate([
        { transform: 'translate(0,0) rotate(0deg)', opacity: 1 },
        { transform: `translate(${drift}px, 105vh) rotate(${rot}deg)`, opacity: 0.9 }
      ], { duration: dur*1000, easing: 'cubic-bezier(0.3,0.1,0.5,1)', delay: Math.random()*400 });
      setTimeout(() => c.remove(), (dur+0.5)*1000);
    }
  }

  function open() {
    if (opened) return;
    opened = true;
    envelope.classList.add('opened');
    envelope.classList.remove('floaty');
    stage.classList.add('is-open');
    setTimeout(() => {
      reveal.classList.add('show');
      fireConfetti();
    }, 900);
  }

  function reset() {
    opened = false;
    reveal.classList.remove('show');
    envelope.classList.remove('opened');
    stage.classList.remove('is-open');
    setTimeout(() => envelope.classList.add('floaty'), 100);
  }

  envelope.addEventListener('click', open);
  replay.addEventListener('click', reset);
</script>

</body>
</html>
